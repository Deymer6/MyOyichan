<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Tema base de la aplicación -->
    <style name="Base.Theme.MyOyichan" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/text_on_primary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorError">@color/error</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:spinnerItemStyle">@style/MyOyichan.SpinnerItem</item>
    </style>

    <!-- Texto oscuro y grande para el valor seleccionado de los Spinner -->
    <style name="MyOyichan.SpinnerItem" parent="@android:style/Widget.TextView.SpinnerItem">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="Theme.MyOyichan" parent="Base.Theme.MyOyichan" />

    <!-- Estilo para botones grandes (adultos mayores) -->
    <style name="Widget.MyOyichan.Button.Large" parent="Widget.Material3.Button">
        <item name="android:minHeight">72dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="iconTint">@color/text_on_primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
    </style>

    <!-- Botón SOS rojo -->
    <style name="Widget.MyOyichan.Button.SOS" parent="Widget.Material3.Button">
        <item name="android:minHeight">72dp</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="iconTint">@color/text_on_primary</item>
        <item name="backgroundTint">@color/sos_red</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
    </style>

    <!-- Botón secundario -->
    <style name="Widget.MyOyichan.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">60dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/primary</item>
        <item name="iconTint">@color/primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="strokeColor">@color/primary</item>
    </style>

    <!-- Overlay que fuerza alto contraste dentro de los campos de texto -->
    <style name="ThemeOverlay.MyOyichan.TextInput" parent="">
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorPrimary">@color/primary</item>
    </style>

    <!-- Estilo para TextInputLayout -->
    <style name="Widget.MyOyichan.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="materialThemeOverlay">@style/ThemeOverlay.MyOyichan.TextInput</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxStrokeWidthFocused">3dp</item>
        <item name="hintTextColor">@color/primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="android:textSize">18sp</item>
    </style>

    <!-- Estilo para textos grandes -->
    <style name="TextAppearance.MyOyichan.Title" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.MyOyichan.Subtitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.MyOyichan.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.MyOyichan.BodySecondary" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Estilo para tarjetas -->
    <style name="Widget.MyOyichan.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="contentPadding">16dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
    </style>

    <!-- Estilo para Toolbar -->
    <style name="Widget.MyOyichan.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/toolbar_background</item>
        <item name="titleTextColor">@color/text_on_primary</item>
        <item name="subtitleTextColor">@color/text_on_primary</item>
    </style>
</resources>